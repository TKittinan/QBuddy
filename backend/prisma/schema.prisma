generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---

enum RoleType {
  ADMIN
  STAFF
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ONLINE
  OFFLINE
  UNVERIFIED
}

enum TicketStatus {
  Waiting
  Serving
  Completed
  Skipped
  Cancelled
}

enum PlaceStatus {
  Active
  Inactive
}

enum ActivityStatus {
  Open
  Closed
  Completed
  Cancelled
}

enum SupportCategory {
  Bug
  Shop_Issue
  General
}

enum SupportStatus {
  Pending
  Resolved
}

// --- Models ---
model ActivityLog {
  id        String   @id @default(cuid())
  userName  String
  action    String
  type      String
  status    String
  createdAt DateTime @default(now())
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  password     String?
  phone        String?
  avatarUrl    String?
  role         RoleType     @default(CUSTOMER)
  status       UserStatus   @default(ACTIVE)
  aiConsented  Boolean      @default(false)
  createdAt    DateTime     @default(now())
  interests    String[]

  // Relations
  hostedActivities PartyActivity[] @relation("HostRelation")
  joinedActivities Guest[]
  supportTickets   SupportTicket[]
  messages         Message[]
}

model Place {
  id              String       @id @default(cuid())
  name            String
  branch          String
  category        String
  status          PlaceStatus  @default(Active)
  description     String?
  address         String?
  phone           String?
  lat             Float
  lng             Float
  openTime        String
  closeTime       String
  avgServiceTime  Int
  queueCount      Int          @default(0)
  logoUrl         String?
  coverUrl        String?
  isRecommended   Boolean      @default(false)
  monthlyBookings Int          @default(0)
  createdAt       DateTime     @default(now())

  // Relations
  tableTypes      TableType[]
  tickets         Ticket[]
  activities      PartyActivity[]
}

model TableType {
  id        String @id @default(cuid())
  label     String
  capacity  Int
  
  placeId   String
  place     Place  @relation(fields: [placeId], references: [id])
}

model Ticket {
  id         String       @id @default(cuid())
  name       String
  email      String?
  service    String
  guests     Int
  bookDate   String?
  bookTime   String?
  tableType  String?
  waitTime   Int?
  status     TicketStatus @default(Waiting)
  createdAt  DateTime     @default(now())

  placeId    String
  place      Place        @relation(fields: [placeId], references: [id])
}

model PartyActivity {
  id               String         @id @default(cuid())
  title            String
  description      String?
  category         String
  tags             String[]
  meetingDate      String
  meetingTime      String
  lat              Float
  lng              Float
  maxGuests        Int
  status           ActivityStatus @default(Open)
  createdAt        DateTime       @default(now())

  // Relations
  hostId           String
  host             User           @relation("HostRelation", fields: [hostId], references: [id])
  placeId          String
  place            Place          @relation(fields: [placeId], references: [id])
  joinedGuests     Guest[]
  
  // Optional: Link to a specific booking/ticket
  bookingId        String?
}

model Guest {
  id         String   @id @default(cuid())
  pax        Int
  status     String   @default("pending")

  userId     String
  user       User     @relation(fields: [userId], references: [id])
  activityId String
  activity   PartyActivity @relation(fields: [activityId], references: [id])

  @@unique([userId, activityId])
}

model SupportTicket {
  id        String          @id @default(cuid())
  subject   String
  category  SupportCategory
  status    SupportStatus   @default(Pending)
  createdAt DateTime        @default(now())

  userId    String
  user      User            @relation(fields: [userId], references: [id])
  messages  Message[]
}

model Message {
  id        String   @id @default(cuid())
  text      String
  timestamp DateTime @default(now())

  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id])
}

model Settings {
  id             Int    @id @default(1)
  businessName   String
  phone          String
  email          String
  maxQueuePerDay Int
  autoCancelMins Int
}